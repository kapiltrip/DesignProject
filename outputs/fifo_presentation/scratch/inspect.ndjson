{"kind":"textbox","text":"10","bbox":[1168,678,58,30]}
{"kind":"textbox","text":"Assertions observe internal controller state and state exactly what must be true after each accepted operation.","bbox":[70,92,1000,42]}
{"kind":"textbox","text":"RST_STATE","bbox":[96,168,212,20]}
{"kind":"textbox","text":"After reset: empty high, full low, pointers zero, count zero","bbox":[350,167,720,24]}
{"kind":"textbox","text":"FULL_FLAG / EMPTY_FLAG","bbox":[96,222,212,20]}
{"kind":"textbox","text":"Flags must match fifo_count == DEPTH and fifo_count == 0","bbox":[350,221,720,24]}
{"kind":"textbox","text":"COUNT_RANGE","bbox":[96,276,212,20]}
{"kind":"textbox","text":"fifo_count must stay within 0..DEPTH","bbox":[350,275,720,24]}
{"kind":"textbox","text":"WRITE_ONLY","bbox":[96,330,212,20]}
{"kind":"textbox","text":"write pointer increments, read pointer stable, count increments","bbox":[350,329,720,24]}
{"kind":"textbox","text":"READ_ONLY","bbox":[96,384,212,20]}
{"kind":"textbox","text":"read pointer increments, write pointer stable, count decrements","bbox":[350,383,720,24]}
{"kind":"textbox","text":"READ_WRITE","bbox":[96,438,212,20]}
{"kind":"textbox","text":"both pointers move while count remains stable","bbox":[350,437,720,24]}
{"kind":"textbox","text":"READ_EMPTY / WRITE_FULL","bbox":[96,492,212,20]}
{"kind":"textbox","text":"invalid requests must be blocked at boundaries","bbox":[350,491,720,24]}
{"kind":"textbox","text":"Example property intent","bbox":[778,527,374,18]}
{"kind":"textbox","text":"READ_ONLY:\n  (!do_write && do_read) |=>\n    wr_ptr == $past(wr_ptr) &&\n    rd_ptr == $past(rd_ptr) + 1'b1 &&\n    fifo_count == $past(fifo_count) - 1'b1;","bbox":[778,551,374,72]}
