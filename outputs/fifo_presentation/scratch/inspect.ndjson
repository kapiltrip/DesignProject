{"kind":"textbox","text":"clk, rst\nwr_en, rd_en\nwr_data","bbox":[98,244,134,50]}
{"kind":"textbox","text":"FIFO controller","bbox":[420,198,210,28]}
{"kind":"textbox","text":"wr_ptr, rd_ptr\nfifo_count\ndo_write, do_read\nfull, empty","bbox":[422,238,206,84]}
{"kind":"textbox","text":"Synchronous RAM","bbox":[820,200,210,28]}
{"kind":"textbox","text":"waddr, raddr\ndin, dout\nwrite enable","bbox":[828,244,194,58]}
{"kind":"textbox","text":"Outputs\n\nrd_data\nfull\nempty","bbox":[1170,204,60,90]}
